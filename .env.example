# Environment Configuration Template

# ==========================================
# GENERAL CONFIGURATION
# ==========================================
NODE_ENV=development
LOG_LEVEL=debug

# ==========================================
# BACKEND API CONFIGURATION
# ==========================================
BACKEND_PORT=5000
BACKEND_HOST=localhost

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
JWT_EXPIRY=7d

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_WS_URL=ws://localhost:5000

# ==========================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password123
DB_NAME=network_monitoring

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ==========================================
# ML SERVICE CONFIGURATION
# ==========================================
ML_SERVICE_PORT=5001
ML_SERVICE_HOST=localhost
ML_MODEL_PATH=models/random_forest_model.pkl
ML_SCALER_PATH=models/scaler.pkl
ML_ENCODERS_PATH=models/encoders.pkl

# ==========================================
# ALERT CONFIGURATION
# ==========================================
ALERT_THRESHOLD=0.7
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_FROM=alerts@network-monitoring.local
ALERT_WEBHOOK_URL=

# ==========================================
# MONITORING & LOGGING
# ==========================================
LOG_DIR=logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14
LOG_FORMAT=combined

# ==========================================
# SECURITY
# ==========================================
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# FEATURE FLAGS
# ==========================================
FEATURE_REAL_TIME_MONITORING=true
FEATURE_BATCH_PROCESSING=true
FEATURE_ADVANCED_ANALYTICS=false
FEATURE_GPU_ACCELERATION=false

# ==========================================
# DOCKER CONFIGURATION
# ==========================================
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_BACKEND=network-monitoring/backend
DOCKER_IMAGE_FRONTEND=network-monitoring/frontend
DOCKER_IMAGE_ML=network-monitoring/ml-service
