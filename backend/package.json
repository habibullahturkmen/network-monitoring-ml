{
  "name": "network-monitoring-backend",
  "version": "1.0.0",
  "description": "Backend API for Network Monitoring ML System",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "network",
    "monitoring",
    "intrusion-detection",
    "machine-learning"
  ],
  "author": "Cyber Experts Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "sequelize": "^6.32.0",
    "pg": "^8.10.0",
    "pg-hstore": "^2.3.4",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "axios": "^1.4.0",
    "express-ratelimit": "^6.7.0",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "winston": "^3.8.2",
    "joi": "^17.9.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/jsonwebtoken": "^9.0.2",
    "typescript": "^5.1.3",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.44.0",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "prettier": "^2.8.8",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.2",
    "ts-jest": "^29.1.0"
  }
}
